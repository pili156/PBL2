generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model MasterRole {
  id        Int     @id @default(autoincrement())
  nama_role String?
  users     User[]

  @@map("master_role")
}

model User {
  id               Int               @id @default(autoincrement())
  email            String?           @unique
  password_hash    String?
  created_at       DateTime?         @default(now()) @db.Timestamptz(6)
  updated_at       DateTime?         @updatedAt @db.Timestamptz(6)
  role_id          Int?
  status_akun      String?           @default("Pending")
  username         String?           @unique
  master_dosen     MasterDosen?
  pengajuan_studi  PengajuanStudi[]
  pesan_komunikasi PesanKomunikasi[]
  activity_logs    ActivityLog[]
  role             MasterRole?       @relation(fields: [role_id], references: [id])

  @@map("users")
}

model MasterDosen {
  id               Int       @id @default(autoincrement())
  user_id          Int?      @unique
  nip              String?   @unique
  nama_lengkap     String?
  pangkat_golongan String?
  jabatan          String?
  unit_kerja       String?
  created_at       DateTime? @default(now()) @db.Timestamptz(6)
  updated_at       DateTime? @updatedAt @db.Timestamptz(6)
  jurusan          String?
  program_studi    String?
  user             User?     @relation(fields: [user_id], references: [id])

  @@map("master_dosen")
}

model MasterJenisStudi {
  id         Int              @id @default(autoincrement())
  nama_jenis String?
  pengajuan  PengajuanStudi[]

  @@map("master_jenis_studi")
}

model MasterJalurPendanaan {
  id             Int              @id @default(autoincrement())
  nama_pendanaan String?
  pengajuan      PengajuanStudi[]

  @@map("master_jalur_pendanaan")
}

model MasterStatusPengajuan {
  id          Int              @id @default(autoincrement())
  nama_status String?
  pengajuan   PengajuanStudi[]

  @@map("master_status_pengajuan")
}

model MasterWilayah {
  id          Int              @id @default(autoincrement())
  nama_wilayah String?
  pengajuan   PengajuanStudi[]

  @@map("master_wilayah")
}

model MasterDokumen {
  id             Int                @id @default(autoincrement())
  nama_dokumen   String?
  is_mandatory   Boolean?           @default(true)
  created_at     DateTime?          @default(now()) @db.Timestamptz(6)
  updated_at     DateTime?          @updatedAt @db.Timestamptz(6)
  syarat_wilayah String?
  dokumen        DokumenPengajuan[]

  @@map("master_dokumen")
}

model PengajuanStudi {
  id                      Int                      @id @default(autoincrement())
  user_id                 Int?
  tanggal_pengajuan       DateTime?                @db.Date
  created_at              DateTime?                @default(now()) @db.Timestamptz(6)
  updated_at              DateTime?                @updatedAt @db.Timestamptz(6)
  jalur_pendanaan_id      Int?
  jenis_studi_id          Int?
  status_id               Int?
  wilayah_studi           Int?
  perguruan_tinggi        String?
  dokumen_pengajuan       DokumenPengajuan[]
  monitoring_khs          MonitoringKhs[]
  pengajuan_reimbursement PengajuanReimbursement[]
  jalur_pendanaan         MasterJalurPendanaan?    @relation(fields: [jalur_pendanaan_id], references: [id])
  jenis_studi             MasterJenisStudi?        @relation(fields: [jenis_studi_id], references: [id])
  status                  MasterStatusPengajuan?   @relation(fields: [status_id], references: [id])
  user                    User?                    @relation(fields: [user_id], references: [id])
  wilayah                 MasterWilayah?           @relation(fields: [wilayah_studi], references: [id])
  pesan_komunikasi        PesanKomunikasi[]
  activity_logs           ActivityLog[]
  sk_kementerian          SkKementerian[]

  @@map("pengajuan_studi")
}

model DokumenPengajuan {
  id                        Int                       @id @default(autoincrement())
  pengajuan_id              Int?
  master_dokumen_id         Int?
  file_path                 String?
  status_verifikasi         String?                   @default("Pending")
  catatan_revisi            String?
  pengajuan_reimbursement_id Int?
  created_at                DateTime?                 @default(now()) @db.Timestamptz(6)
  updated_at                DateTime?                 @updatedAt @db.Timestamptz(6)
  master_dokumen            MasterDokumen?            @relation(fields: [master_dokumen_id], references: [id])
  pengajuan_studi           PengajuanStudi?           @relation(fields: [pengajuan_id], references: [id])
  pengajuan_reimbursement   PengajuanReimbursement?   @relation(fields: [pengajuan_reimbursement_id], references: [id])

  @@map("dokumen_pengajuan")
}

model SkKementerian {
  id              Int             @id @default(autoincrement())
  pengajuan_id    Int?
  nomor_sk        String?
  file_sk_path    String?
  tanggal_terbit  DateTime?       @db.Date
  status_studi    String?
  pengajuan_studi PengajuanStudi? @relation(fields: [pengajuan_id], references: [id])

  @@map("sk_kementerian")
}

model MonitoringKhs {
  id               Int             @id @default(autoincrement())
  pengajuan_id     Int?
  semester_ke      Int?
  file_khs_path    String?
  catatan_evaluasi String?
  tanggal_unggah   DateTime?       @db.Date
  created_at       DateTime?       @default(now()) @db.Timestamptz(6)
  tahun_akademik   String?
  ipk              Decimal?        @db.Decimal(3, 2)
  status_evaluasi  String?         @default("Pending")
  tanggal_evaluasi DateTime?       @db.Timestamptz(6)
  updated_at       DateTime?       @updatedAt @db.Timestamptz(6)
  pengajuan_studi  PengajuanStudi? @relation(fields: [pengajuan_id], references: [id])

  @@map("monitoring_khs")
}

model PengajuanReimbursement {
  id                Int             @id @default(autoincrement())
  pengajuan_id      Int?
  jenis_pengajuan   String?         @default("reimbursement")
  semester_ke       Int?
  tahun_akademik    String?
  tahun_ke          Int?
  file_bukti_bayar  String?
  nominal           Decimal?        @db.Decimal(12, 2)
  status_pencairan  String?         @default("Pending")
  catatan_keuangan  String?
  nomor_rekening    String?
  nama_bank         String?
  created_at        DateTime?       @default(now()) @db.Timestamptz(6)
  tanggal_pencairan DateTime?       @db.Timestamptz(6)
  updated_at        DateTime?       @updatedAt @db.Timestamptz(6)
  pengajuan_studi     PengajuanStudi?    @relation(fields: [pengajuan_id], references: [id])
  dokumen_pengajuan   DokumenPengajuan[]

  @@map("pengajuan_reimbursement")
}

model PesanKomunikasi {
  id              Int             @id @default(autoincrement())
  pengajuan_id    Int?
  pengirim_id     Int?
  isi_pesan       String?
  waktu_kirim     DateTime?       @default(now()) @db.Timestamptz(6)
  pengajuan_studi PengajuanStudi? @relation(fields: [pengajuan_id], references: [id])
  pengirim        User?           @relation(fields: [pengirim_id], references: [id])

  @@map("pesan_komunikasi")
}

model ActivityLog {
  id           Int             @id @default(autoincrement())
  user_id      Int?
  pengajuan_id Int?
  aktivitas    String?
  tipe         String?
  created_at   DateTime?       @default(now()) @db.Timestamptz(6)
  created_by   String?

  user       User?           @relation(fields: [user_id], references: [id])
  pengajuan  PengajuanStudi? @relation(fields: [pengajuan_id], references: [id])

  @@map("activity_logs")
}
